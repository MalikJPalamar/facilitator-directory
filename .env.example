# ─── The Directory — environment template ───────────────────────────────────
# Copy to .env and fill in. Every service reads from here via @directory/config.

# Database (Postgres + PostGIS + pgvector). docker-compose provisions this locally.
DATABASE_URL="postgres://directory:directory@localhost:5432/directory"

# Auth (Better Auth — also the OAuth 2.1 / MCP authorization server)
BETTER_AUTH_SECRET="change-me-with-a-long-random-string"
BETTER_AUTH_URL="http://localhost:3000"

# AI — Claude. Default model lives in @directory/ai (claude-opus-4-8).
ANTHROPIC_API_KEY="sk-ant-..."

# Public REST + OpenAPI API (Hono)
API_BASE_URL="http://localhost:8787"
API_PORT="8787"

# MCP server (remote, streamable-HTTP)
MCP_PORT="8788"

# Stripe (test mode)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_ID="price_..."

# Analytics (PostHog) — optional locally; the durable analytics_event stream always works.
POSTHOG_API_KEY=""
POSTHOG_HOST="https://us.i.posthog.com"

# Search (Typesense) — deferred; the Postgres impl is the default this scaffold.
TYPESENSE_HOST="localhost"
TYPESENSE_PORT="8108"
TYPESENSE_API_KEY="dev-typesense-key"
