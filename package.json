{
  "name": "the-directory",
  "private": true,
  "version": "0.0.0",
  "description": "The Directory — an AI-native marketplace that turns a school's certified graduates into a discoverable, agent-accessible directory.",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @directory/db generate",
    "db:migrate": "pnpm --filter @directory/db migrate",
    "db:seed": "pnpm --filter @directory/db seed",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "intelligence:nightly": "pnpm --filter @directory/worker nightly",
    "journey": "pnpm --filter @directory/worker journey",
    "provision-school": "pnpm --filter @directory/worker provision"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "@types/node": "^22.10.2"
  },
  "pnpm": {
    "overrides": {
      "@modelcontextprotocol/sdk": "1.29.0"
    }
  }
}
